---
// Cozy-inn styled newsletter signup.
// Posts directly to MailerLite's unauthenticated form-subscribe endpoint —
// no server, no token exposed, no /api/ route needed.
//
// Account ID: 2271322   (from your MailerLite embed URL)
// Form ID:    184855632701032232
//
// To replace the form visual with an illustration, drop an image into
// /public/illustrations/inn-ledger.jpg and set hasIllustration=true below.
---

<section class="newsletter">
  <div class="newsletter-card">
    <div class="newsletter-illustration" aria-hidden="true">
      <img
        src="/illustrations/newsletter-hero.jpg"
        alt=""
        width="140"
        height="140"
        loading="lazy"
        decoding="async"
        style="width:100%;height:auto;border-radius:3px;display:block;"
      />
    </div>

    <div class="newsletter-text">
      <h3>Sign the guestbook</h3>
      <p class="lead">
        New cozy fantasy. Occasional reading recommendations. Early looks at the
        next Crossroads Inn book, when it's ready.
      </p>
      <p class="small">No spam. No schedule. Unsubscribe whenever.</p>

      <form
        id="newsletter-form"
        class="newsletter-form"
        action="https://assets.mailerlite.com/jsonp/2271322/forms/184855632701032232/subscribe"
        method="POST"
      >
        <label class="visually-hidden" for="newsletter-email">Email address</label>
        <input
          id="newsletter-email"
          type="email"
          name="fields[email]"
          placeholder="your@email.com"
          autocomplete="email"
          required
        />
        <input type="hidden" name="ml-submit" value="1" />
        <input type="hidden" name="anticsrf" value="true" />
        <button type="submit">
          <span>Sign</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12 L19 12 M13 6 L19 12 L13 18" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </form>
      <p id="newsletter-message" class="newsletter-message" aria-live="polite"></p>
    </div>
  </div>
</section>

<style>
  .newsletter {
    margin: 3.5rem 0;
  }
  .newsletter-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.5rem;
    background:
      linear-gradient(135deg, rgba(243, 235, 217, 0.9), rgba(250, 246, 239, 0.9)),
      radial-gradient(ellipse at top left, rgba(168, 102, 58, 0.08), transparent 60%),
      radial-gradient(ellipse at bottom right, rgba(85, 107, 74, 0.06), transparent 60%);
    border: 1px solid rgba(168, 102, 58, 0.25);
    border-radius: 6px;
    padding: 2rem 1.75rem;
    position: relative;
    box-shadow:
      inset 0 0 0 1px rgba(255, 250, 240, 0.6),
      0 2px 0 rgba(168, 102, 58, 0.08),
      0 12px 32px -12px rgba(42, 32, 23, 0.1);
  }
  /* Warm corner ornaments */
  .newsletter-card::before,
  .newsletter-card::after {
    content: "";
    position: absolute;
    width: 28px;
    height: 28px;
    border: 1px solid rgba(168, 102, 58, 0.4);
    opacity: 0.6;
  }
  .newsletter-card::before {
    top: 10px; left: 10px;
    border-right: none;
    border-bottom: none;
  }
  .newsletter-card::after {
    bottom: 10px; right: 10px;
    border-left: none;
    border-top: none;
  }

  @media (min-width: 640px) {
    .newsletter-card {
      grid-template-columns: 140px 1fr;
      padding: 2.25rem 2rem;
      gap: 2rem;
      align-items: center;
    }
  }

  .newsletter-illustration {
    display: none;
  }
  @media (min-width: 640px) {
    .newsletter-illustration {
      display: block;
    }
  }

  .newsletter-text h3 {
    margin: 0 0 0.5rem;
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .newsletter-text .lead {
    margin: 0 0 0.5rem;
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.5;
  }
  .newsletter-text .small {
    margin: 0 0 1.25rem;
    color: var(--ink-soft);
    font-size: 0.85rem;
    opacity: 0.8;
    font-style: italic;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .newsletter-form input[type="email"] {
    flex: 1 1 14rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid rgba(168, 102, 58, 0.4);
    background: #fffcf6;
    border-radius: 3px;
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 1rem;
    color: var(--ink);
    transition: border-color 200ms, background 200ms;
  }
  .newsletter-form input[type="email"]:focus {
    outline: none;
    border-color: var(--warm);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(168, 102, 58, 0.15);
  }
  .newsletter-form input[type="email"]::placeholder {
    color: rgba(78, 66, 54, 0.5);
  }

  .newsletter-form button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--warm);
    color: #fffaf0;
    border: none;
    padding: 0.7rem 1.25rem;
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    border-radius: 3px;
    cursor: pointer;
    transition: background 200ms, transform 100ms;
  }
  .newsletter-form button:hover {
    background: #8f5530;
  }
  .newsletter-form button:active {
    transform: translateY(1px);
  }

  .newsletter-message {
    margin: 0.75rem 0 0;
    font-size: 0.9rem;
    min-height: 1.2rem;
    color: var(--ink-soft);
  }
  .newsletter-message.success { color: var(--leaf); font-weight: 600; }
  .newsletter-message.error { color: #9a4040; }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }
</style>

<script>
  // Intercept the native form submit so we can show inline feedback
  // without a full page reload to MailerLite's confirmation page.
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const msg = document.getElementById('newsletter-message');

  if (form && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = form.querySelector<HTMLInputElement>('input[type="email"]');
      const email = emailInput?.value?.trim();
      if (!email) return;

      msg.textContent = 'Signing…';
      msg.className = 'newsletter-message';

      try {
        // MailerLite's JSONP-style endpoint accepts form-encoded POSTs.
        // The no-cors submission means we can't read the response, but
        // MailerLite does process the subscription reliably.
        const body = new URLSearchParams();
        body.set('fields[email]', email);
        body.set('ml-submit', '1');
        body.set('anticsrf', 'true');

        await fetch(form.action, {
          method: 'POST',
          mode: 'no-cors',
          body,
        });

        msg.textContent = 'Signed. Welcome to the inn — check your email to confirm.';
        msg.className = 'newsletter-message success';
        form.reset();
      } catch {
        msg.textContent = 'Something went wrong. Please try again in a moment.';
        msg.className = 'newsletter-message error';
      }
    });
  }
</script>
