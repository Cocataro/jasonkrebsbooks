---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';

const title = 'Jason Krebs — Cozy Fantasy';
const description = 'Cozy fantasy novels by Jason Krebs. The Crossroads Inn series — books for rainy afternoons.';
---

<Layout title={title} description={description}>
  <div class="hero-banner">
    <img
      src="/illustrations/hero-v1-exterior-dusk.jpg"
      alt="A cozy stone inn at dusk — warm golden light glowing from its windows, cobblestone path winding through autumn trees beneath a sunset sky"
      width="1920"
      height="800"
      loading="eager"
      decoding="async"
      class="hero-img"
    />
  </div>
  <main>
    <header class="hero">
      <p class="eyebrow">A cozy fantasy series</p>
      <h1 class="series-title">The Crossroads Inn</h1>
      <p class="tagline">
        An ex-mercenary becomes the reluctant keeper of a magical inn at the
        crossroads of five realms — healing others while trying to outrun her
        own past.
      </p>
    </header>

    <div class="ornament" aria-hidden="true">
      <img src="/illustrations/divider-vine.svg" alt="" width="600" height="60" class="divider-svg" />
    </div>

    <section class="book-feature" aria-labelledby="book-one-heading">
      <div class="book-mockup-wrap">
        <img
          src="/illustrations/book-mockup-b1.jpg"
          alt="Book One — The Crossroads Inn, coming soon (cover mockup)"
          width="600"
          height="900"
          loading="lazy"
          decoding="async"
          class="book-mockup"
        />
      </div>
      <div class="book-feature-copy">
        <p class="eyebrow">Book One</p>
        <h2 id="book-one-heading">The Crossroads Inn</h2>
        <p class="book-hook">
          The inn at the crossroads doesn't choose its keeper. It keeps her.
        </p>
        <p>
          The first of six cozy fantasy novels. Warm windows, tired travellers,
          and a doorway every road leads back to.
        </p>
        <p class="soon">
          Coming soon — <a href="/follow">follow for release alerts</a>.
        </p>
      </div>
    </section>

    <div class="ornament" aria-hidden="true">
      <img src="/illustrations/divider-sprig.svg" alt="" width="600" height="60" class="divider-svg" />
    </div>

    <section class="about-preview">
      <h2>About Jason</h2>
      <p>
        Jason Krebs writes cozy fantasy about tired people, warm rooms, and
        found families. He drinks more tea than coffee, lives somewhere drafty,
        and believes the best stories start with someone opening a door.
      </p>
      <p>
        <a href="/about">More about Jason →</a>
      </p>
    </section>

    <div class="ornament" aria-hidden="true">
      <img src="/illustrations/divider-lantern.svg" alt="" width="600" height="90" class="divider-svg" />
    </div>

    <Newsletter />

    <div class="ornament" aria-hidden="true">
      <img src="/illustrations/divider-teacup.svg" alt="" width="600" height="80" class="divider-svg" />
    </div>

    <section class="blog-preview">
      <h2>From the inn</h2>
      <p class="tagline">Notes on cozy fantasy, reading recommendations, and quiet thoughts.</p>
      <p>
        <a href="/blog">Read the blog →</a>
      </p>
    </section>
  </main>
</Layout>

<style>
  /* ── Hero banner: full-width landscape image above the fold ── */
  .hero-banner {
    width: 100%;
    max-height: 50vh;
    overflow: hidden;
    background: var(--bg-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-banner:empty {
    display: none;
  }
  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: center 40%;
    max-height: 50vh;
  }

  /* ── Hero text block ── */
  .hero {
    text-align: center;
    padding: 2.5rem 0 3rem;
  }
  .eyebrow {
    color: var(--warm);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    font-family: var(--font-heading);
  }
  .series-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    margin: 0.25rem 0 1.25rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: var(--ink);
  }
  .tagline {
    max-width: 38ch;
    margin: 0 auto;
  }
  .soon {
    color: var(--ink-soft);
    font-style: italic;
    margin-top: 2rem;
    font-size: 1.05rem;
  }

  /* ── Ornamental SVG dividers ── */
  .ornament {
    text-align: center;
    margin: 2.5rem 0;
    line-height: 1;
  }
  .divider-svg {
    display: inline-block;
    max-width: 100%;
    height: auto;
    opacity: 0.85;
  }

  /* ── Content sections ── */
  .about-preview, .blog-preview {
    margin: 2.5rem 0;
  }

  /* ── Book 1 feature ── */
  .book-feature {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    margin: 3rem 0;
  }
  .book-mockup-wrap {
    flex: 0 0 38%;
    max-width: 260px;
  }
  .book-mockup {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 3px;
    box-shadow:
      0 1px 2px rgba(42, 32, 23, 0.08),
      0 10px 30px -6px rgba(42, 32, 23, 0.28);
  }
  .book-feature-copy {
    flex: 1 1 auto;
  }
  .book-feature-copy h2 {
    margin: 0.25rem 0 1rem;
  }
  .book-hook {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--ink);
    margin: 0 0 1rem;
    line-height: 1.35;
  }

  /* ── Mobile refinements ── */
  @media (max-width: 640px) {
    .hero {
      padding: 2rem 0 2.5rem;
    }
    .divider-svg {
      max-width: 80%;
    }
    .book-feature {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }
    .book-mockup-wrap {
      flex-basis: auto;
      max-width: 220px;
    }
    .book-hook {
      font-size: 1.2rem;
    }
  }
</style>
