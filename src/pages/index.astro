---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';

const title = 'Jason Krebs — Cozy Fantasy';
const description = 'Cozy fantasy novels by Jason Krebs. The Crossroads Inn series — books for rainy afternoons.';
---

<Layout title={title} description={description}>
  <main>
    <header class="hero">
      <div class="hero-illustration">
        <img
          src="/illustrations/newsletter-hero.jpg"
          alt="A warm inn counter with an open ledger, lanterns, and shelves of bottles and curiosities"
          width="800"
          height="800"
          loading="eager"
          decoding="async"
        />
      </div>
      <p class="eyebrow">A cozy fantasy series</p>
      <h1>The Crossroads Inn</h1>
      <p class="tagline">
        An ex-mercenary becomes the reluctant keeper of a magical inn at the
        crossroads of five realms — healing others while trying to outrun her
        own past.
      </p>
      <p class="soon">Book 1 coming soon.</p>
    </header>

    <div class="ornament" aria-hidden="true">&#10044;</div>

    <section class="about-preview">
      <h2>About Jason</h2>
      <p>
        Jason Krebs writes cozy fantasy about tired people, warm rooms, and
        found families. He drinks more tea than coffee, lives somewhere drafty,
        and believes the best stories start with someone opening a door.
      </p>
      <p>
        <a href="/about">More about Jason &rarr;</a>
      </p>
    </section>

    <div class="ornament" aria-hidden="true">&#10044;</div>

    <Newsletter />

    <div class="ornament" aria-hidden="true">&#10044;</div>

    <section class="blog-preview">
      <h2>From the inn</h2>
      <p class="tagline">Notes on cozy fantasy, reading recommendations, and quiet thoughts.</p>
      <p>
        <a href="/blog">Read the blog &rarr;</a>
      </p>
    </section>
  </main>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 1rem 0 3rem;
  }
  .hero-illustration {
    max-width: 320px;
    margin: 0 auto 2rem;
    border-radius: 8px;
    overflow: hidden;
    box-shadow:
      0 4px 24px -8px rgba(42, 32, 23, 0.2),
      0 1px 3px rgba(42, 32, 23, 0.1);
    border: 3px solid rgba(168, 102, 58, 0.2);
  }
  .hero-illustration img {
    display: block;
    width: 100%;
    height: auto;
  }
  .eyebrow {
    color: var(--warm);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    font-family: 'EB Garamond', serif;
  }
  .hero h1 {
    font-size: 3.5rem;
    margin: 0.5rem 0 1rem;
  }
  .soon {
    color: var(--ink-soft);
    font-style: italic;
    margin-top: 2rem;
  }
  .ornament {
    text-align: center;
    color: var(--warm-soft);
    font-size: 1.2rem;
    margin: 2.5rem 0;
    opacity: 0.5;
    letter-spacing: 0.5em;
  }
  .about-preview, .blog-preview {
    margin: 2rem 0;
  }
</style>
