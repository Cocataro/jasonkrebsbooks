---
import Layout from '../layouts/Layout.astro';
import Newsletter from '../components/Newsletter.astro';

const title = 'Jason Krebs — Cozy Fantasy';
const description = 'Cozy fantasy novels by Jason Krebs. The Crossroads Inn series — books for rainy afternoons.';
---

<Layout title={title} description={description}>
  <div class="hero-banner">
    <img
      src="/illustrations/hero-landing.jpg"
      alt="The Crossroads Inn at dusk — warm light glowing from its windows, five roads meeting beneath a twilight sky"
      width="1920"
      height="800"
      loading="eager"
      decoding="async"
      class="hero-img"
      onerror="this.parentElement.classList.add('hero-banner--no-img')"
    />
  </div>
  <main>
    <header class="hero">
      <p class="eyebrow">A cozy fantasy series</p>
      <h1 class="series-title">The Crossroads Inn</h1>
      <p class="tagline">
        An ex-mercenary becomes the reluctant keeper of a magical inn at the
        crossroads of five realms — healing others while trying to outrun her
        own past.
      </p>
      <p class="soon">Book 1 coming soon.</p>
    </header>

    <div class="ornament" aria-hidden="true"><span>✦</span></div>

    <section class="about-preview">
      <h2>About Jason</h2>
      <p>
        Jason Krebs writes cozy fantasy about tired people, warm rooms, and
        found families. He drinks more tea than coffee, lives somewhere drafty,
        and believes the best stories start with someone opening a door.
      </p>
      <p>
        <a href="/about">More about Jason →</a>
      </p>
    </section>

    <div class="ornament" aria-hidden="true"><span>✦</span></div>

    <Newsletter />

    <div class="ornament" aria-hidden="true"><span>✦</span></div>

    <section class="blog-preview">
      <h2>From the inn</h2>
      <p class="tagline">Notes on cozy fantasy, reading recommendations, and quiet thoughts.</p>
      <p>
        <a href="/blog">Read the blog →</a>
      </p>
    </section>
  </main>
</Layout>

<style>
  /* ── Hero banner: full-width landscape image above the fold ── */
  .hero-banner {
    width: 100%;
    max-height: 50vh;
    overflow: hidden;
    background: var(--bg-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-banner--no-img {
    display: none;
  }
  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: center 40%;
    max-height: 50vh;
  }

  /* ── Hero text block ── */
  .hero {
    text-align: center;
    padding: 2.5rem 0 3rem;
  }
  .eyebrow {
    color: var(--warm);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.8rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    font-family: var(--font-heading);
  }
  .series-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    margin: 0.25rem 0 1.25rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: var(--ink);
  }
  .tagline {
    max-width: 38ch;
    margin: 0 auto;
  }
  .soon {
    color: var(--ink-soft);
    font-style: italic;
    margin-top: 2rem;
    font-size: 1.05rem;
  }

  /* ── Ornamental dividers ── */
  .ornament {
    text-align: center;
    margin: 2.5rem 0;
    line-height: 1;
  }
  .ornament span {
    display: inline-block;
    color: var(--warm-soft);
    font-size: 0.9rem;
    opacity: 0.55;
    position: relative;
  }
  .ornament span::before,
  .ornament span::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 4rem;
    height: 1px;
    background: var(--warm-soft);
    opacity: 0.4;
  }
  .ornament span::before {
    right: calc(100% + 0.75rem);
  }
  .ornament span::after {
    left: calc(100% + 0.75rem);
  }

  /* ── Content sections ── */
  .about-preview, .blog-preview {
    margin: 2.5rem 0;
  }

  /* ── Mobile refinements ── */
  @media (max-width: 640px) {
    .hero {
      padding: 2rem 0 2.5rem;
    }
    .ornament span::before,
    .ornament span::after {
      width: 2.5rem;
    }
  }
</style>
