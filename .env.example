# Copy this to .env.local and fill in real values. Never commit .env.local.

# MailerLite API token (Integrations → API in MailerLite dashboard)
MAILERLITE_API_TOKEN=
# MailerLite group ID for main newsletter list (create in MailerLite → Subscribers → Groups)
MAILERLITE_GROUP_ID=

# Public site URL (used for canonical links, RSS, OpenGraph)
PUBLIC_SITE_URL=https://jasonkrebsbooks.com
